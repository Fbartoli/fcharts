{
  "name": "sightline",
  "version": "0.1.0",
  "description": "Charts that render 100k+ points at 60fps and pass the accessibility audit at the same time.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=23.6"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/sightline.js",
  "module": "./dist/sightline.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/sightline.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "test": "node --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bench": "node bench/harness.ts",
    "size": "node scripts/size.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "axe-core": "^4.10.2",
    "playwright": "^1.49.1",
    "typescript": "^5.7.2",
    "uplot": "^1.6.31",
    "vite": "^6.0.5"
  }
}
