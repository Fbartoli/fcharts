{
  "name": "sightline",
  "version": "0.1.0",
  "description": "Charts that render 100k+ points at 60fps and pass the accessibility audit at the same time.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=23.6"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src/compliance"
  ],
  "main": "./dist/sightline.js",
  "module": "./dist/sightline.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/sightline.umd.cjs",
  "jsdelivr": "./dist/sightline.umd.cjs",
  "bin": {
    "sightline-audit": "./src/compliance/cli.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/sightline.js",
      "require": "./dist/sightline.umd.cjs"
    },
    "./compliance": {
      "types": "./src/compliance/index.ts",
      "import": "./src/compliance/index.ts"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "landing": "SIGHTLINE_ROOT=landing vite",
    "build": "vite build && SIGHTLINE_ENTRY=react vite build && tsc -p tsconfig.build.json && node scripts/fix-dts.mjs",
    "pack:sdk": "pnpm build && pnpm pack",
    "preview": "vite preview",
    "test": "node --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bench": "node bench/harness.ts",
    "a11y-audit": "node src/compliance/cli.ts --fixture ./a11y/fixture.ts --edition en301549 --out ./compliance-out",
    "size": "node scripts/size.mjs"
  },
  "peerDependencies": {
    "axe-core": "^4.10.0",
    "playwright": "^1.49.0",
    "react": ">=18",
    "vite": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "axe-core": {
      "optional": true
    },
    "playwright": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.16",
    "axe-core": "^4.10.2",
    "playwright": "^1.49.1",
    "typescript": "^5.7.2",
    "uplot": "^1.6.31",
    "vite": "^6.0.5"
  }
}
