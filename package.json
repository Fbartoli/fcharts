{
  "name": "fcharts-js",
  "version": "0.1.0",
  "description": "Charts that render 100k+ points at 60fps and pass the accessibility audit at the same time.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=23.6"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/fcharts.js",
  "module": "./dist/fcharts.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/fcharts.umd.cjs",
  "jsdelivr": "./dist/fcharts.umd.cjs",
  "bin": {
    "fcharts-audit": "./dist/compliance/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/fcharts.js",
      "require": "./dist/fcharts.umd.cjs"
    },
    "./compliance": {
      "types": "./dist/compliance/index.d.ts",
      "import": "./dist/compliance/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "landing": "SIGHTLINE_ROOT=landing vite",
    "build": "vite build && SIGHTLINE_ENTRY=react vite build && SIGHTLINE_ENTRY=compliance vite build && tsc -p tsconfig.build.json && node scripts/fix-dts.mjs",
    "build:site": "SIGHTLINE_ENTRY=site vite build",
    "preview:site": "pnpm build:site && npx wrangler pages dev dist-site",
    "pack:sdk": "pnpm build && pnpm pack",
    "preview": "vite preview",
    "test": "node --test test/*.test.ts",
    "test:browser": "node --test test/browser/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint src test bench landing a11y scripts",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm test:browser",
    "bench": "node bench/harness.ts",
    "a11y-audit": "node src/compliance/cli.ts --fixture ./a11y/fixture.ts --edition en301549 --out ./compliance-out",
    "size": "node scripts/size.mjs"
  },
  "peerDependencies": {
    "axe-core": "^4.10.0",
    "playwright": "^1.49.0",
    "react": ">=18",
    "vite": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "axe-core": {
      "optional": true
    },
    "playwright": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.16",
    "axe-core": "^4.10.2",
    "highcharts": "^12.6.0",
    "oxlint": "^1.68.0",
    "playwright": "^1.49.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.7.2",
    "uplot": "^1.6.31",
    "vite": "^6.0.5"
  }
}
